NAVIDROME_ENABLED=true
NAVIDROME_BASE_URL=http://127.0.0.1:4533
NAVIDROME_USERNAME=admin
NAVIDROME_PASSWORD=
NAVIDROME_ALLOWED_USERS=Nirotiy

# Optional local overrides
# NAVIDROME_CLIENT=musicparty-dev
# NAVIDROME_API_VERSION=1.16.1

# Local upload/transcode library
LOCAL_LIBRARY_ENABLED=true
LOCAL_LIBRARY_PATH=data/local-library
# Admin can always upload. Add comma-separated MusicParty display names here for non-admin upload/edit/delete.
LOCAL_LIBRARY_ALLOWED_USERS=
LOCAL_LIBRARY_MAX_UPLOAD_BYTES=209715200
MULTIPART_MAX_FILE_SIZE=200MB
MULTIPART_MAX_REQUEST_SIZE=220MB
